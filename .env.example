# ===========================================
# BFF → ai-layer / data-miner (server-only)
# ===========================================
AI_LAYER_URL=http://localhost:8001
AI_LAYER_KEY=your_ai_layer_key_here
DATA_MINER_URL=http://localhost:8000
DATA_MINER_KEY=your_data_miner_key_here
# Header X-Rm-Bff khi gọi Tiki/FPT — trùng BFF_CLIENT_TOKEN bên data-miner
DATA_MINER_BFF_TOKEN=your_shared_bff_token

# ===========================================
# Supabase
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_key_here

# Optional — history client (legacy)
# NEXT_PUBLIC_AI_LAYER_URL=http://localhost:8001
# NEXT_PUBLIC_AI_LAYER_KEY=your_ai_layer_key_here

# ===========================================
# Site URL (FE domain — dùng cho origin guard)
# ===========================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ===========================================
# API Guard (RmSign + chặn /api ngoài app)
# ===========================================
# Server-only. Random string dài.
API_GUARD_SECRET=change_me_to_a_long_random_string
# Ký request BFF (challenge + X-Rm-Sign)
API_GUARD_ENABLED=true
# Chặn curl/Postman/cross-origin → trả 404. Dev: tắt nếu chưa cần test guard.
API_ORIGIN_GUARD_ENABLED=false

# ===========================================
NODE_ENV=development
